{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git grep *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(rg *)",
      "Bash(bd *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(timeout *)",
      "Bash(echo *)",
      "Read(~/.claude/*)",
      "Edit(~/.claude/*)",
      "Read(~/.beads/*)",
      "Write(~/.beads/*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(printenv *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/.claude",
      "~/.beads",
      "/tmp/claude"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "noti -m \"Claude is waiting...\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        ".beads/bd.sock"
      ]
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Crossing the Rubicon",
      "Salting the fields of Carthage",
      "Awaiting the Ides of March",
      "Consulting the Oracle at Delphi",
      "Holding at Thermopylae",
      "Sacking Rome",
      "Marching on Moscow",
      "Storming the Bastille",
      "Nailing theses to a church door",
      "Deciphering the Rosetta Stone",
      "Sailing past the Pillars of Hercules",
      "Searching the Library of Alexandria",
      "Drafting the Magna Carta",
      "Signing the Treaty of Westphalia",
      "Opening Tutankhamun's tomb",
      "Debating in the Agora",
      "Besieging the walls of Troy",
      "Traversing the Silk Road",
      "Crowning Charlemagne",
      "Launching the Mayflower",
      "Summiting Everest",
      "Splitting the atom",
      "Landing at Normandy",
      "Building the Great Wall",
      "Forging Excalibur",
      "Translating the Dead Sea Scrolls",
      "Laying siege to Constantinople",
      "Charting the Northwest Passage",
      "Assembling the Terracotta Army",
      "Erecting the Colossus of Rhodes",
      "Tunneling under the Berlin Wall",
      "Convening the Council of Nicaea",
      "Navigating the Strait of Magellan",
      "Building the Pyramids",
      "Printing the Gutenberg Bible",
      "Surveying the Panama Canal",
      "Ratifying the Constitution",
      "Wintering at Valley Forge",
      "Cracking the Enigma Code",
      "Raising the columns of the Parthenon",
      "Igniting the Olympic flame",
      "Unearthing the city of Ur",
      "Launching Sputnik",
      "Circumnavigating the globe",
      "Founding the Library of Alexandria",
      "Raising the walls of Babylon",
      "Sealing the Treaty of Tordesillas",
      "Telegraphing \"What hath God wrought\"",
      "Carving Mount Rushmore",
      "Laying the transatlantic cable",
      "Excavating Machu Picchu",
      "Riding with the Mongol Horde",
      "Irrigating the Fertile Crescent",
      "Inaugurating the Trans-Siberian Railway",
      "Witnessing the supernova of 1054",
      "Mapping the moons of Jupiter",
      "Sailing to Greenland",
      "Crowning William the Conqueror",
      "Establishing the Knights Templar",
      "Building Himeji Castle",
      "Inscribing Ashoka's edicts",
      "Designing the Taj Mahal",
      "Deciphering Aryabhata's mathematics"
    ]
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "skipAutoPermissionPrompt": true,
  "autoCompactEnabled": false,
  "teammateMode": "auto",
  "remoteControlAtStartup": false
}
